# ── Plex connection ────────────────────────────────────────────────────────────
# URL of your Plex server. Change localhost to an IP for a networked server.
PLEX_URL=http://localhost:32400

# Your Plex authentication token.
# Find it here: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your_token_here

# ── Library ────────────────────────────────────────────────────────────────────
# Optional: which music library to use. Leave blank to use the first one found.
PLEX_LIBRARY_NAME=

# ── File paths ─────────────────────────────────────────────────────────────────
# Default output CSV for export (overridden by --output flag)
OUTPUT_FILE=plex_music_export.csv

# Default input CSV for import (overridden by --file flag)
IMPORT_FILE=plex_music_export.csv

# Default log CSV for both export and import operations (overridden by --log flag)
LOG_FILE=plex_music_log.csv
